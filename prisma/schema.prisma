// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator js {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

model User {
  id        String            @unique() @default(uuid())
  name      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt()
  userId    String            @unique
  spaces    ReplicacheSpace[]
}

model ReplicacheSpace {
  spaceId  String    @unique()
  version  Int       @default(0)
  userId   String
  user     User      @relation(fields: [userId], references: [userId])
  messages Message[]
}

model ReplicacheClientGroup {
  id      String             @unique()
  spaceId String
  clients ReplicacheClient[]
}

model ReplicacheClient {
  id                  String @unique()
  clientGroupId       String
  lastMutationId      Int
  lastModifiedVersion Int
  clientId            String @unique()

  ReplicacheClientGroup   ReplicacheClientGroup? @relation(fields: [replicacheClientGroupId], references: [id])
  replicacheClientGroupId String?
}

model Message {
  id String @unique()

  from    String
  ord     Int
  content String

  lastModifiedVersion Int
  deleted             Boolean

  space   ReplicacheSpace @relation(fields: [spaceId], references: [spaceId])
  spaceId String
}
